<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="true">

  <targets async="true">

    <target xsi:type="File"
            name="file"
            fileName="${basedir}/logs/agent-${shortdate}.log"
            archiveFileName="${basedir}/logs/archive/agent-{#}.log"
            archiveEvery="Day"
            archiveNumbering="Date"
            maxArchiveFiles="30"
            encoding="utf-8"
            layout="${longdate} | ${level:uppercase=true:padding=-5} | ${logger:shortName=true} | ${message} ${exception:format=tostring}" />

    <target xsi:type="ColoredConsole"
            name="console"
            layout="${time} | ${level:uppercase=true:padding=-5} | ${logger:shortName=true} | ${message} ${exception:format=message}" />

    <target xsi:type="EventLog"
            name="eventlog"
            source="HpcLite Agent"
            log="Application"
            layout="${level:uppercase=true} | ${logger:shortName=true} | ${message} ${exception:format=message}" />

  </targets>

  <rules>
    <logger name="Microsoft.*"  minlevel="Warn"  writeTo="file,console" final="true" />
    <logger name="System.*"     minlevel="Warn"  writeTo="file,console" final="true" />
    <logger name="*"            minlevel="Info"  writeTo="file,console" />
    <logger name="*"            minlevel="Error" writeTo="eventlog" />
  </rules>

</nlog>
