<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="true">

  <targets async="true">

    <target xsi:type="File"
            name="file"
            fileName="${basedir}/logs/scheduler-${shortdate}.log"
            archiveFileName="${basedir}/logs/archive/scheduler-{#}.log"
            archiveEvery="Day"
            archiveNumbering="Date"
            maxArchiveFiles="30"
            encoding="utf-8"
            layout="${longdate} | ${level:uppercase=true:padding=-5} | ${logger:shortName=true} | ${message} ${exception:format=tostring}" />

    <target xsi:type="ColoredConsole"
            name="console"
            layout="${time} | ${level:uppercase=true:padding=-5} | ${logger:shortName=true} | ${message} ${exception:format=message}" />

    <target xsi:type="EventLog"
            name="eventlog"
            source="HpcLite Scheduler"
            log="Application"
            layout="${level:uppercase=true} | ${logger:shortName=true} | ${message} ${exception:format=message}" />

  </targets>

  <rules>
    <!-- Watchdog errors → EventLog aussi -->
    <logger name="*WatchdogService*" minlevel="Error"   writeTo="eventlog" />

    <!-- ASP.NET Core internal : Warning+ seulement -->
    <logger name="Microsoft.*"       minlevel="Warn"    writeTo="file,console" final="true" />
    <logger name="System.*"          minlevel="Warn"    writeTo="file,console" final="true" />

    <!-- Tout le reste -->
    <logger name="*"                 minlevel="Info"    writeTo="file,console" />
  </rules>

</nlog>
