<mxfile>
  <diagram name="Architecture">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- UI Layer -->
        <mxCell id="stx" value="STX Frontend&#xa;(HTML/JS)" style="rounded=1;fillColor=#cce5ff;" vertex="1" parent="1">
          <mxGeometry x="200" y="40" width="180" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="fetead" value="FETEAD Web App&#xa;(ASP.NET)" style="rounded=1;fillColor=#cce5ff;" vertex="1" parent="1">
          <mxGeometry x="450" y="40" width="220" height="60" as="geometry"/>
        </mxCell>

        <!-- Job API -->
        <mxCell id="jobapi" value="Styx.JobApi&#xa;(REST API)" style="rounded=1;fillColor=#003366;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="320" y="140" width="200" height="70" as="geometry"/>
        </mxCell>

        <!-- File Share -->
        <mxCell id="fileshare" value="File Share&#xa;\\fileserver\share" style="shape=cylinder;fillColor=#eeeeee;" vertex="1" parent="1">
          <mxGeometry x="600" y="150" width="120" height="80" as="geometry"/>
        </mxCell>

        <!-- Scheduler -->
        <mxCell id="scheduler" value="Styx.SchedulerProcess" style="rounded=1;fillColor=#ffcc99;" vertex="1" parent="1">
          <mxGeometry x="200" y="260" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- Runner Server -->
        <mxCell id="runnerServer" value="Runner.Server&#xa;(SignalR)" style="rounded=1;fillColor=#ffcc99;" vertex="1" parent="1">
          <mxGeometry x="200" y="340" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- Workers -->
        <mxCell id="worker1" value="Worker 1" style="rounded=1;" vertex="1" parent="1">
          <mxGeometry x="150" y="430" width="100" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="worker2" value="Worker 2" style="rounded=1;" vertex="1" parent="1">
          <mxGeometry x="270" y="430" width="100" height="50" as="geometry"/>
        </mxCell>

        <!-- HPC Lite -->
        <mxCell id="hpcScheduler" value="HpcLite.Scheduler" style="rounded=1;fillColor=#ccffcc;" vertex="1" parent="1">
          <mxGeometry x="550" y="260" width="200" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="hpcAgent" value="HpcLite.Agent" style="rounded=1;fillColor=#ccffcc;" vertex="1" parent="1">
          <mxGeometry x="550" y="340" width="200" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="hpcRunner" value="HpcLite.Runner" style="rounded=1;fillColor=#ccffcc;" vertex="1" parent="1">
          <mxGeometry x="550" y="420" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- Database -->
        <mxCell id="db" value="PostgreSQL" style="shape=cylinder;fillColor=#cccccc;" vertex="1" parent="1">
          <mxGeometry x="380" y="520" width="150" height="80" as="geometry"/>
        </mxCell>

        <!-- Connections -->
        <mxCell edge="1" parent="1" source="stx" target="jobapi"/>
        <mxCell edge="1" parent="1" source="jobapi" target="fileshare"/>
        <mxCell edge="1" parent="1" source="jobapi" target="scheduler"/>
        <mxCell edge="1" parent="1" source="scheduler" target="runnerServer"/>
        <mxCell edge="1" parent="1" source="runnerServer" target="worker1"/>
        <mxCell edge="1" parent="1" source="runnerServer" target="worker2"/>
        <mxCell edge="1" parent="1" source="jobapi" target="hpcScheduler"/>
        <mxCell edge="1" parent="1" source="hpcScheduler" target="hpcAgent"/>
        <mxCell edge="1" parent="1" source="hpcAgent" target="hpcRunner"/>
        <mxCell edge="1" parent="1" source="hpcRunner" target="db"/>
        <mxCell edge="1" parent="1" source="runnerServer" target="db"/>
        <mxCell edge="1" parent="1" source="jobapi" target="db"/>
        <mxCell edge="1" parent="1" source="fetead" target="db"/>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>